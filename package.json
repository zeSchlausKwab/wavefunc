{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "relay": "cd relay && go run . --port 3334",
    "relay:reset": "cd relay && go run . --reset-all",
    "contextvm": "bun run contextvm/server.ts",
    "dev": "bun run relay & sleep 1 && bun run migrate && bun run contextvm & bun --hot src/index.tsx",
    "dev:fake": "bun run relay & sleep 1 && bun run scripts/seed.ts && bun run contextvm & bun --hot src/index.tsx",
    "dev:no-seed": "bun run relay & sleep 1 && bun run contextvm & bun --hot src/index.tsx",
    "dev:frontend": "bun --hot src/index.tsx",
    "seed": "bun run scripts/seed.ts",
    "migrate": "bun run scripts/migrate_legacy.ts",
    "start": "NODE_ENV=production bun src/index.tsx",
    "build": "bun run build.ts",
    "tauri": "tauri",
    "tauri:dev": "bun run relay & sleep 1 && bun run migrate && bun run contextvm & tauri dev",
    "tauri:build": "tauri build",
    "tauri:android": "tauri android init && tauri android dev",
    "tauri:android:build": "tauri android build"
  },
  "dependencies": {
    "@contextvm/sdk": "^0.1.29",
    "@faker-js/faker": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@nostr-dev-kit/ndk": "2.17.2",
    "@nostr-dev-kit/ndk-cache-dexie": "2.6.44",
    "@nostr-dev-kit/ndk-hooks": "^1.3.4",
    "@nostr-dev-kit/ndk-wallet": "^0.7.1",
    "@nostr-dev-kit/sync": "^0.3.4",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-router": "^1.132.47",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.1",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.13",
    "lucide-react": "^0.545.0",
    "nostr-tools": "^2.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-use": "^17.6.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/bun": "^1.2.23",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "npm:@socotra/modelcontextprotocol-sdk"
  }
}
