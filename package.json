{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "relay": "cd relay && go run . --port 3334",
    "relay:reset": "cd relay && go run . --reset-all",
    "dev": "bun run relay & sleep 1 && bun run migrate && bun --hot src/index.tsx",
    "dev:fake": "bun run relay & sleep 1 && bun run scripts/seed.ts && bun --hot src/index.tsx",
    "dev:no-seed": "bun run relay & sleep 1 && bun --hot src/index.tsx",
    "dev:frontend": "bun --hot src/index.tsx",
    "seed": "bun run scripts/seed.ts",
    "migrate": "bun run scripts/migrate_legacy.ts",
    "start": "NODE_ENV=production bun src/index.tsx",
    "build": "bun run build.ts",
    "tauri": "tauri",
    "tauri:dev": "bun run relay & sleep 1 && bun run migrate && tauri dev",
    "tauri:build": "tauri build",
    "tauri:android": "tauri android init && tauri android dev",
    "tauri:android:build": "tauri android build"
  },
  "dependencies": {
    "@faker-js/faker": "^10.0.0",
    "@nostr-dev-kit/ndk": "2.14.32",
    "@nostr-dev-kit/ndk-cache-dexie": "2.6.33",
    "@nostr-dev-kit/ndk-hooks": "^1.3.0",
    "@nostr-dev-kit/ndk-wallet": "^0.6.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.1",
    "bun-plugin-tailwind": "^0.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "nostr-tools": "^2.17.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/bun": "latest",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9"
  }
}
