{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "relay": "cd relay && go run . --port 3334",
    "relay:reset": "./scripts/kill-relay.sh && cd relay && go run . --reset-all",
    "relay:kill": "./scripts/kill-relay.sh",
    "contextvm": "bun run contextvm/server.ts",
    "dev": "./scripts/dev-clean.sh",
    "dev:old": "bun run relay & sleep 1 && bun run migrate && bun run contextvm & bun --hot src/index.tsx",
    "dev:fake": "bun run relay & sleep 1 && bun run scripts/seed.ts && bun run contextvm & bun --hot src/index.tsx",
    "dev:no-seed": "bun run relay & sleep 1 && bun run contextvm & bun --hot src/index.tsx",
    "dev:frontend": "bun --hot src/index.tsx",
    "seed": "bun run scripts/seed.ts",
    "migrate": "bun run scripts/migrate_legacy.ts",
    "start": "NODE_ENV=production bun src/index.tsx",
    "build": "bun run build.ts",
    "tauri": "tauri",
    "tauri:dev": "bun run relay & sleep 1 && bun run migrate && bun run contextvm & tauri dev",
    "tauri:build": "tauri build",
    "tauri:android": "tauri android init && tauri android dev",
    "tauri:android:build": "tauri android build"
  },
  "dependencies": {
    "@contextvm/sdk": "^0.1.29",
    "@faker-js/faker": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@nostr-dev-kit/blossom": "^6.1.0",
    "@nostr-dev-kit/messages": "^0.1.3",
    "@nostr-dev-kit/ndk": "^2.17.10",
    "@nostr-dev-kit/ndk-cache-dexie": "2.6.44",
    "@nostr-dev-kit/react": "^1.3.12",
    "@nostr-dev-kit/sync": "^0.3.5",
    "@nostr-dev-kit/wallet": "^0.8.7",
    "@nostr-dev-kit/wot": "^0.3.6",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-form": "^1.23.7",
    "@tanstack/react-router": "^1.132.47",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.1",
    "@yudiel/react-qr-scanner": "^2.3.1",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.13",
    "jsqr": "^1.4.0",
    "nostr-tools": "^2.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-use": "^17.6.0",
    "react18-json-view": "^0.2.9",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/bun": "^1.2.23",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "npm:@socotra/modelcontextprotocol-sdk"
  }
}
