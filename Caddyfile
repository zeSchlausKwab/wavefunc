# Replace with your actual domain or IP
# For IP-based access (no HTTPS):
:80 {
    # Nostr relay WebSocket endpoint
    handle /relay/* {
        reverse_proxy localhost:3334
    }

    # Main web application
    handle {
        reverse_proxy localhost:3000
    }

    # Enable gzip compression
    encode gzip

    # Access logs
    log {
        output file /var/log/caddy/wavefunc-access.log
        format json
    }
}

